# Appwrite Configuration
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_API_KEY=your_api_key_here

# External API Configuration
CNN_DATAVIZ_API_URL=https://production.dataviz.cnn.io
YAHOO_FINANCE_API_URL=https://query1.finance.yahoo.com

# Cache Configuration
CACHE_TTL_SECONDS=300
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Trial Configuration
TRIAL_DURATION_MINUTES=15

# IP Lookup Services (fallback chain)
IP_SERVICE_PRIMARY=https://api.ipify.org?format=json
IP_SERVICE_SECONDARY=https://api.my-ip.io/ip.json
IP_SERVICE_TERTIARY=https://ipapi.co/json

# Logging Configuration
LOG_LEVEL=info
NEXT_PUBLIC_VERCEL_ENV=development

# AI Configuration (Optional - for BYOK and Hosted AI tiers)
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
HOSTED_AI_ENDPOINT=

# Subscription & Payment (Optional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Ads Configuration (Optional - for Free tier)
ADS_PROVIDER_ID=
